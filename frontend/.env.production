# =============================================================================
# 6FB BOOKING PLATFORM - RAILWAY PRODUCTION ENVIRONMENT
# =============================================================================
# Production environment variables for Next.js frontend
# Updated: 2025-06-27 - Cleaned up for Railway deployment

# =============================================================================
# API CONFIGURATION (REQUIRED)
# =============================================================================
# Backend API URL - production endpoint (currently using Render backend)
NEXT_PUBLIC_API_URL=https://sixfb-backend.onrender.com/api/v1

# Application URL for OAuth callbacks and webhooks
NEXT_PUBLIC_APP_URL=https://your-frontend.up.railway.app

# WebSocket URL for real-time features
NEXT_PUBLIC_WS_URL=wss://sixfb-backend.onrender.com/ws

# =============================================================================
# PAYMENT PROCESSING (REQUIRED)
# =============================================================================
# Stripe Configuration - Production keys (must be updated for production)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51RbMZpPNpTbxU6Sges2slnfQWOO7nll4xYCSEUSYtjuQ667EU0rkhmQlghK0nDu5x1WnyiKNRGT2kMrEOXnIWsXD00whqgT2DQ

# =============================================================================
# ENVIRONMENT SETTINGS (REQUIRED)
# =============================================================================
# Environment mode
NEXT_PUBLIC_ENVIRONMENT=production

# Demo mode (disable in production)
NEXT_PUBLIC_DEMO_MODE=false

# CORS proxy usage (disable in production)
NEXT_PUBLIC_USE_CORS_PROXY=false

# =============================================================================
# GOOGLE INTEGRATIONS (OPTIONAL - Update with real values if needed)
# =============================================================================
# Google Calendar Integration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GOOGLE_API_KEY=your_google_api_key
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=https://your-frontend.up.railway.app/api/auth/google/callback

# =============================================================================
# ANALYTICS & MONITORING (OPTIONAL - Update with real values if needed)
# =============================================================================
# Google Analytics 4 - Use NEXT_PUBLIC_GA_TRACKING_ID (not GA_MEASUREMENT_ID)
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# Note: Sentry variables removed - not currently implemented in codebase