# 6FB Booking Platform - Frontend Configuration
# Copy this file to .env.local and update with your values

# =============================================================================
# REQUIRED: Core Settings
# =============================================================================
# Environment: development, staging, or production
NODE_ENV=development

# Backend API URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# =============================================================================
# REQUIRED: Stripe (for payment processing)
# =============================================================================
# Get from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# =============================================================================
# OPTIONAL: Analytics & Tracking
# =============================================================================
# Google Analytics 4 - Get from https://analytics.google.com
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# Google Tag Manager - Get from https://tagmanager.google.com
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Meta (Facebook) Pixel - Get from https://business.facebook.com/events_manager
# NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id

# =============================================================================
# OPTIONAL: Google APIs
# =============================================================================
# Google Maps API Key - Get from https://console.cloud.google.com
# Required for location features and maps
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Enable Google integrations
# NEXT_PUBLIC_GOOGLE_BUSINESS_ENABLED=true
# NEXT_PUBLIC_GOOGLE_RESERVE_ENABLED=true

# =============================================================================
# OPTIONAL: Feature Flags
# =============================================================================
# Control which features are enabled in the UI
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_REWARDS=true
# NEXT_PUBLIC_ENABLE_GIFT_CERTIFICATES=true
# NEXT_PUBLIC_ENABLE_WAITLIST=true
# NEXT_PUBLIC_ENABLE_INVENTORY=true

# =============================================================================
# OPTIONAL: UI Customization
# =============================================================================
# Business name and branding
# NEXT_PUBLIC_BUSINESS_NAME=6FB Platform
# NEXT_PUBLIC_BUSINESS_PHONE=+1-234-567-8900
# NEXT_PUBLIC_BUSINESS_EMAIL=info@yourdomain.com

# Theme customization
# NEXT_PUBLIC_PRIMARY_COLOR=#1a1a1a
# NEXT_PUBLIC_SECONDARY_COLOR=#f0f0f0
# NEXT_PUBLIC_ACCENT_COLOR=#007bff

# =============================================================================
# OPTIONAL: Development Tools
# =============================================================================
# Enable debug mode for development
# NEXT_PUBLIC_DEBUG_MODE=false

# Mock data for development
# NEXT_PUBLIC_USE_MOCK_DATA=false

# API request timeout (milliseconds)
# NEXT_PUBLIC_API_TIMEOUT=30000

# =============================================================================
# Build Configuration
# =============================================================================
# These are used during build time only (no NEXT_PUBLIC_ prefix)

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Build ID for versioning
# BUILD_ID=local

# Analytics at build time
# ANALYZE=false