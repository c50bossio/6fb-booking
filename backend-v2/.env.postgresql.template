# BookedBarber V2 - PostgreSQL Production Environment Configuration
# 
# 🔒 CRITICAL SECURITY NOTICE:
# - NEVER commit .env files to version control
# - Copy this file to .env.production and fill in your actual values  
# - Use strong, unique passwords for all PostgreSQL users
# - Ensure SSL/TLS is enabled for all database connections
# - Rotate credentials regularly (quarterly recommended)
# - Monitor database logs for unauthorized access attempts
#
# ⚠️  POSTGRESQL MIGRATION REQUIREMENTS:
# - Run database setup script first: psql -f database/postgresql_setup.sql
# - Apply Alembic migrations: alembic upgrade head
# - Run data migration script: python database/migrate_sqlite_to_postgresql.py
# - Verify data integrity after migration
# - Configure connection pooling with pgBouncer

# =============================================================================
# CORE APPLICATION SETTINGS
# =============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=false

APP_NAME=BookedBarber V2 Production
APP_VERSION=2.0.0

# =============================================================================
# POSTGRESQL DATABASE CONFIGURATION
# =============================================================================
# Primary database connection
DATABASE_URL=postgresql://bookedbarber_app:${APP_DB_PASSWORD}@${DB_HOST}:${DB_PORT}/bookedbarber_v2

# Connection via pgBouncer (recommended for production)
# DATABASE_URL=postgresql://bookedbarber_app:${APP_DB_PASSWORD}@localhost:6432/bookedbarber_v2

# Database connection pool settings
DB_POOL_SIZE=25
DB_MAX_OVERFLOW=50
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# Read-only database connection for analytics
READONLY_DATABASE_URL=postgresql://bookedbarber_readonly:${READONLY_DB_PASSWORD}@${DB_HOST}:${DB_PORT}/bookedbarber_v2

# Database host and connection details
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookedbarber_v2
DB_USER=bookedbarber_app
DB_READONLY_USER=bookedbarber_readonly

# Database passwords (SET THESE IN ENVIRONMENT VARIABLES)
APP_DB_PASSWORD=
READONLY_DB_PASSWORD=
BACKUP_DB_PASSWORD=

# SSL Configuration (REQUIRED for production)
DB_SSLMODE=require
DB_SSLCERT=/path/to/client-cert.pem
DB_SSLKEY=/path/to/client-key.pem
DB_SSLROOTCERT=/path/to/ca-cert.pem

# =============================================================================
# STAGING DATABASE CONFIGURATION
# =============================================================================
# Staging environment database
STAGING_DATABASE_URL=postgresql://bookedbarber_app:${APP_DB_PASSWORD}@${DB_HOST}:${DB_PORT}/bookedbarber_v2_staging

# =============================================================================
# TESTING DATABASE CONFIGURATION
# =============================================================================
# Test database (for automated testing)
TEST_DATABASE_URL=postgresql://bookedbarber_app:${APP_DB_PASSWORD}@${DB_HOST}:${DB_PORT}/bookedbarber_v2_test

# =============================================================================
# BACKUP AND RECOVERY CONFIGURATION
# =============================================================================
# Database backup settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM UTC
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=bookedbarber-backups
BACKUP_S3_PREFIX=postgresql/
BACKUP_ENCRYPTION_KEY=${BACKUP_ENCRYPTION_KEY}

# Point-in-time recovery settings
PITR_ENABLED=true
WAL_ARCHIVING=true
ARCHIVE_COMMAND=s3cmd put %p s3://bookedbarber-wal-archive/%f

# =============================================================================
# SECURITY & AUTHENTICATION (PostgreSQL Optimized)
# =============================================================================
# 🔒 CRITICAL SECURITY KEYS - MUST BE CHANGED FOR PRODUCTION
SECRET_KEY=${SECRET_KEY}  # Generate with: openssl rand -hex 32
JWT_SECRET_KEY=${JWT_SECRET_KEY}  # Generate with: openssl rand -hex 32

# JWT Settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password security
BCRYPT_ROUNDS=12

# Database security
DB_CONNECTION_TIMEOUT=10
DB_STATEMENT_TIMEOUT=30000  # 30 seconds
DB_LOCK_TIMEOUT=10000      # 10 seconds

# =============================================================================
# PERFORMANCE AND MONITORING
# =============================================================================
# Query performance monitoring
SLOW_QUERY_LOG=true
SLOW_QUERY_THRESHOLD=1000  # Log queries slower than 1 second
LOG_STATEMENT=all          # Log all SQL statements (disable in production)

# Connection monitoring
CONNECTION_POOL_MONITORING=true
CONNECTION_HEALTH_CHECK_INTERVAL=30

# PostgreSQL-specific performance settings
SHARED_BUFFERS=256MB
EFFECTIVE_CACHE_SIZE=1GB
WORK_MEM=4MB
MAINTENANCE_WORK_MEM=64MB
CHECKPOINT_COMPLETION_TARGET=0.9
WAL_BUFFERS=16MB
DEFAULT_STATISTICS_TARGET=100

# =============================================================================
# REDIS CONFIGURATION (Enhanced for PostgreSQL)
# =============================================================================
# Redis for caching and session management
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# Redis cluster configuration (for high availability)
REDIS_CLUSTER_ENABLED=false
REDIS_CLUSTER_NODES=${REDIS_HOST}:${REDIS_PORT}

# Cache settings
CACHE_DEFAULT_TIMEOUT=300
CACHE_QUERY_TIMEOUT=900    # Cache database queries for 15 minutes
CACHE_SESSION_TIMEOUT=3600 # Cache sessions for 1 hour

# =============================================================================
# STRIPE PAYMENT CONFIGURATION (Production)
# =============================================================================
# Production Stripe keys
STRIPE_SECRET_KEY=${STRIPE_LIVE_SECRET_KEY}
STRIPE_PUBLISHABLE_KEY=${STRIPE_LIVE_PUBLISHABLE_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_LIVE_WEBHOOK_SECRET}

# Stripe Connect for barber payouts
STRIPE_CONNECT_CLIENT_ID=${STRIPE_CONNECT_CLIENT_ID}

# Payment security
PAYMENT_TIMEOUT=30
IDEMPOTENCY_KEY_TTL=86400  # 24 hours

# =============================================================================
# EMAIL CONFIGURATION (Production)
# =============================================================================
# SendGrid production configuration
SENDGRID_API_KEY=${SENDGRID_LIVE_API_KEY}
SENDGRID_FROM_EMAIL=support@bookedbarber.com
SENDGRID_FROM_NAME=BookedBarber

# Email rate limiting
EMAIL_RATE_LIMIT_PER_HOUR=1000
EMAIL_QUEUE_BATCH_SIZE=100

# =============================================================================
# SMS CONFIGURATION (Production)
# =============================================================================
# Twilio production configuration
TWILIO_ACCOUNT_SID=${TWILIO_LIVE_ACCOUNT_SID}
TWILIO_AUTH_TOKEN=${TWILIO_LIVE_AUTH_TOKEN}
TWILIO_PHONE_NUMBER=${TWILIO_LIVE_PHONE_NUMBER}

# SMS rate limiting
SMS_RATE_LIMIT_PER_HOUR=500
SMS_QUEUE_BATCH_SIZE=50

# =============================================================================
# CORS & FRONTEND CONFIGURATION (Production)
# =============================================================================
# Production allowed origins
ALLOWED_ORIGINS=https://app.bookedbarber.com,https://bookedbarber.com
FRONTEND_URL=https://app.bookedbarber.com
BACKEND_URL=https://api.bookedbarber.com

# =============================================================================
# MONITORING & ERROR TRACKING (Production)
# =============================================================================
# Sentry for error tracking
SENTRY_DSN=${SENTRY_LIVE_DSN}
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=${GIT_COMMIT_HASH}

# Production sampling rates
SENTRY_SAMPLE_RATE=0.8              # Sample 80% of errors
SENTRY_TRACES_SAMPLE_RATE=0.05      # Sample 5% of transactions
SENTRY_PROFILES_SAMPLE_RATE=0.02    # Sample 2% of profiles

# Privacy settings
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ATTACH_STACKTRACE=true
SENTRY_MAX_BREADCRUMBS=50

# Database monitoring
DB_MONITORING_ENABLED=true
DB_METRICS_COLLECTION_INTERVAL=60
DB_SLOW_QUERY_ALERTS=true

# =============================================================================
# SECURITY HEADERS AND SETTINGS (Production)
# =============================================================================
# Security headers
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000  # 1 year
SECURE_CONTENT_TYPE_NOSNIFF=true
SECURE_BROWSER_XSS_FILTER=true
SECURE_FRAME_DENY=true

# Session security
SECURE_COOKIE_HTTPONLY=true
SECURE_COOKIE_SECURE=true
SECURE_COOKIE_SAMESITE=Lax

# CSRF protection
CSRF_PROTECTION_ENABLED=true
CSRF_SECRET_KEY=${CSRF_SECRET_KEY}

# =============================================================================
# RATE LIMITING (Production)
# =============================================================================
# API rate limiting
RATE_LIMIT_PER_MINUTE=500
AUTH_RATE_LIMIT_PER_MINUTE=20
PAYMENT_RATE_LIMIT_PER_MINUTE=10

# Database query rate limiting
DB_CONNECTION_RATE_LIMIT=100
DB_QUERY_RATE_LIMIT=1000

# =============================================================================
# LOGGING CONFIGURATION (Production)
# =============================================================================
# Application logging
LOG_FORMAT=json
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5
LOG_COMPRESSION=true

# Database logging
DB_LOG_LEVEL=WARNING
DB_LOG_QUERIES=false      # Disable in production for performance
DB_LOG_SLOW_QUERIES=true
DB_LOG_CONNECTIONS=false

# Audit logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_LOG_ENCRYPTION=true

# =============================================================================
# CELERY TASK QUEUE CONFIGURATION
# =============================================================================
# Celery broker (Redis)
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2

# Task routing
CELERY_TASK_ROUTES={
    'emails.*': {'queue': 'email'},
    'sms.*': {'queue': 'sms'},
    'payments.*': {'queue': 'payments'},
    'reports.*': {'queue': 'reports'}
}

# Worker configuration
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================
# Health check settings
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# Database health checks
DB_HEALTH_CHECK_QUERY=SELECT 1
DB_HEALTH_CHECK_TIMEOUT=5
DB_CONNECTION_POOL_HEALTH_CHECK=true

# External service health checks
STRIPE_HEALTH_CHECK=true
SENDGRID_HEALTH_CHECK=true
TWILIO_HEALTH_CHECK=true

# =============================================================================
# FEATURE FLAGS (Production)
# =============================================================================
# Core features
ENABLE_GOOGLE_CALENDAR=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_WEBHOOKS=true

# Advanced features
ENABLE_AI_INSIGHTS=true
ENABLE_PREDICTIVE_ANALYTICS=true
ENABLE_ADVANCED_REPORTING=true
ENABLE_MULTI_LOCATION=true

# Security features
ENABLE_MFA=true
ENABLE_AUDIT_LOGGING=true
ENABLE_RATE_LIMITING=true
ENABLE_SECURITY_HEADERS=true

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# Deployment platform settings
DEPLOYMENT_PLATFORM=render  # or railway, vercel, aws, gcp, azure
DEPLOYMENT_REGION=us-east-1

# Auto-scaling settings
MIN_INSTANCES=2
MAX_INSTANCES=10
TARGET_CPU_UTILIZATION=70
SCALE_UP_COOLDOWN=300
SCALE_DOWN_COOLDOWN=600

# =============================================================================
# ENVIRONMENT VARIABLES TO SET EXTERNALLY
# =============================================================================
# These must be set as environment variables, not in this file:
#
# Database passwords:
# - APP_DB_PASSWORD
# - READONLY_DB_PASSWORD  
# - BACKUP_DB_PASSWORD
#
# Security keys:
# - SECRET_KEY
# - JWT_SECRET_KEY
# - CSRF_SECRET_KEY
# - BACKUP_ENCRYPTION_KEY
#
# Service API keys:
# - STRIPE_LIVE_SECRET_KEY
# - STRIPE_LIVE_PUBLISHABLE_KEY
# - STRIPE_LIVE_WEBHOOK_SECRET
# - SENDGRID_LIVE_API_KEY
# - TWILIO_LIVE_ACCOUNT_SID
# - TWILIO_LIVE_AUTH_TOKEN
# - TWILIO_LIVE_PHONE_NUMBER
# - SENTRY_LIVE_DSN
#
# Infrastructure:
# - DB_HOST
# - DB_PORT
# - REDIS_HOST
# - REDIS_PORT
# - REDIS_PASSWORD
#
# =============================================================================
# VALIDATION CHECKLIST
# =============================================================================
# Before deploying to production, verify:
# ✓ All passwords are strong and unique
# ✓ SSL/TLS is configured for database connections
# ✓ All API keys are production (not test) keys
# ✓ CORS origins match your actual domains
# ✓ Debug mode is disabled
# ✓ Logging is configured appropriately
# ✓ Backup and monitoring are set up
# ✓ Rate limiting is enabled
# ✓ Security headers are configured
# ✓ Health checks are working