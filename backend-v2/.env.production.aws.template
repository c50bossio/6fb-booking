# BookedBarber V2 - AWS Production Environment Configuration
# =============================================================
# Specialized configuration for AWS deployment with ElastiCache
# Copy this file to .env.production and customize for your AWS setup

# =============================================================================
# AWS ENVIRONMENT SETTINGS
# =============================================================================
ENVIRONMENT=production
CLOUD_PROVIDER=aws
AWS_REGION=us-east-1  # Change to your preferred AWS region

# =============================================================================
# AWS ELASTICACHE CONFIGURATION (PRIMARY)
# =============================================================================
# ElastiCache Redis Configuration
AWS_ELASTICACHE_ENABLED=true
AWS_ELASTICACHE_CLUSTER_ID=bookedbarber-redis-prod
AWS_ELASTICACHE_PRIMARY_ENDPOINT=  # Will be set after cluster creation
AWS_ELASTICACHE_READER_ENDPOINT=  # Will be set after cluster creation
AWS_ELASTICACHE_PORT=6379
AWS_ELASTICACHE_SSL=true
AWS_ELASTICACHE_AUTH_TOKEN=  # Set your Redis AUTH token

# ElastiCache Instance Configuration
AWS_ELASTICACHE_NODE_TYPE=cache.t4g.small  # Start small, scale up as needed
AWS_ELASTICACHE_NUM_CACHE_NODES=1  # Single node for small deployments
AWS_ELASTICACHE_ENGINE_VERSION=7.0  # Latest Redis version
AWS_ELASTICACHE_PARAMETER_GROUP=default.redis7.x
AWS_ELASTICACHE_SUBNET_GROUP=bookedbarber-cache-subnet
AWS_ELASTICACHE_SECURITY_GROUPS=sg-xxxxxxxxx  # Will be created by script

# ElastiCache Maintenance and Backup
AWS_ELASTICACHE_MAINTENANCE_WINDOW=sun:05:00-sun:07:00  # Sunday 5-7 AM UTC
AWS_ELASTICACHE_BACKUP_RETENTION_PERIOD=7  # 7 days
AWS_ELASTICACHE_BACKUP_WINDOW=03:00-05:00  # 3-5 AM UTC
AWS_ELASTICACHE_PREFERRED_AZ=us-east-1a  # Change to your preferred AZ

# =============================================================================
# REDIS CONNECTION CONFIGURATION
# =============================================================================
# Redis URL will be auto-generated from ElastiCache endpoint
REDIS_URL=  # Auto-populated by AWS detection script
REDIS_PASSWORD=${AWS_ELASTICACHE_AUTH_TOKEN}
REDIS_SSL=true
REDIS_SSL_CERT_REQS=required
REDIS_SSL_CA_CERTS=/etc/ssl/certs/ca-certificates.crt

# Connection Pool Optimization for AWS
REDIS_MAX_CONNECTIONS=100  # Higher for cloud deployment
REDIS_MIN_IDLE_CONNECTIONS=20
REDIS_CONNECTION_TIMEOUT=30  # Higher for network latency
REDIS_SOCKET_TIMEOUT=10
REDIS_SOCKET_KEEPALIVE=true
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30

# =============================================================================
# AWS VPC AND NETWORKING
# =============================================================================
AWS_VPC_ID=  # Your VPC ID
AWS_SUBNET_IDS=subnet-xxxxxxxx,subnet-yyyyyyyy  # Comma-separated subnet IDs
AWS_AVAILABILITY_ZONES=us-east-1a,us-east-1b  # Multi-AZ for high availability

# Security Group Configuration
AWS_ELASTICACHE_SECURITY_GROUP_NAME=bookedbarber-elasticache-sg
AWS_API_SECURITY_GROUP_ID=  # Your API server security group
AWS_ALLOWED_CIDR_BLOCKS=10.0.0.0/16  # Your VPC CIDR block

# =============================================================================
# AWS CLOUDWATCH MONITORING
# =============================================================================
CLOUDWATCH_ENABLED=true
CLOUDWATCH_NAMESPACE=BookedBarber/Redis
CLOUDWATCH_REGION=${AWS_REGION}
CLOUDWATCH_LOG_GROUP=/aws/elasticache/bookedbarber
CLOUDWATCH_LOG_RETENTION_DAYS=30

# CloudWatch Alarms
CLOUDWATCH_ALARM_EMAIL=ops@bookedbarber.com  # Email for alerts
CLOUDWATCH_ALARM_SNS_TOPIC=bookedbarber-redis-alerts

# Alarm Thresholds
CLOUDWATCH_MEMORY_THRESHOLD=80  # Memory usage percentage
CLOUDWATCH_CPU_THRESHOLD=70  # CPU usage percentage
CLOUDWATCH_CONNECTION_THRESHOLD=45  # Connection count
CLOUDWATCH_HIT_RATE_THRESHOLD=85  # Cache hit rate percentage
CLOUDWATCH_EVICTION_THRESHOLD=100  # Evictions per minute

# =============================================================================
# AWS SECRETS MANAGER INTEGRATION
# =============================================================================
AWS_SECRETS_MANAGER_ENABLED=false  # Enable for enhanced security
AWS_SECRETS_MANAGER_REGION=${AWS_REGION}
AWS_SECRET_NAME_REDIS=bookedbarber/redis/credentials
AWS_SECRET_NAME_DATABASE=bookedbarber/database/credentials
AWS_SECRET_NAME_STRIPE=bookedbarber/stripe/credentials

# =============================================================================
# PERFORMANCE OPTIMIZATION FOR AWS
# =============================================================================
# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL_DEFAULT=300
CACHE_TTL_BOOKINGS=60
CACHE_TTL_ANALYTICS=1800
CACHE_TTL_STATIC=3600
CACHE_TTL_USER_SESSIONS=86400
CACHE_KEY_PREFIX=6fb:
CACHE_COMPRESSION=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100  # Higher for production
RATE_LIMIT_PER_HOUR=2000
RATE_LIMIT_PER_DAY=20000
RATE_LIMIT_REDIS_KEY_PREFIX=rate:
RATE_LIMIT_SLIDING_WINDOW=true

# Redis Memory Management
REDIS_MAX_MEMORY_POLICY=allkeys-lru
REDIS_NOTIFY_KEYSPACE_EVENTS=Ex
REDIS_SLOW_LOG_ENABLED=true
REDIS_SLOW_LOG_THRESHOLD=10000

# =============================================================================
# AWS-SPECIFIC APPLICATION SETTINGS
# =============================================================================
# Application
DEBUG=false
LOG_LEVEL=INFO
PORT=8000

# Security Keys (Store in AWS Secrets Manager in production)
SECRET_KEY=  # Generate 64-character secure key
JWT_SECRET_KEY=  # Generate 64-character secure key

# Database (AWS RDS)
DATABASE_URL=postgresql://username:password@your-rds-endpoint:5432/bookedbarber
DATABASE_SSL_MODE=require  # Required for RDS

# Frontend URLs
FRONTEND_URL=https://app.bookedbarber.com
ALLOWED_ORIGINS=https://app.bookedbarber.com,https://bookedbarber.com

# =============================================================================
# EXTERNAL SERVICES (Production Keys)
# =============================================================================
# Stripe (Live keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SendGrid
SENDGRID_API_KEY=SG....
EMAIL_FROM_ADDRESS=notifications@bookedbarber.com
EMAIL_FROM_NAME=BookedBarber

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Google Services
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://api.bookedbarber.com/api/google-calendar/callback

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================
# Sentry
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Application Performance Monitoring
ENABLE_APM=true
APM_SERVICE_NAME=bookedbarber-api
APM_ENVIRONMENT=production

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
SECURE_HEADERS_ENABLED=true
HSTS_ENABLED=true
CONTENT_SECURITY_POLICY_ENABLED=true

# Feature Flags
ENABLE_MFA=true
ENABLE_WEBHOOKS=true
ENABLE_AI_FEATURES=true
ENABLE_DEMO_MODE=false

# Performance
WORKER_COUNT=4
CONNECTION_POOL_SIZE=20
REQUEST_TIMEOUT=30

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# 1. Run scripts/setup_aws_elasticache.py to create ElastiCache cluster
# 2. Update AWS_ELASTICACHE_PRIMARY_ENDPOINT after cluster creation
# 3. Configure security groups using scripts/configure_elasticache_security.py
# 4. Set up CloudWatch monitoring using monitoring/cloudwatch_alerts.py
# 5. Test connection using scripts/test_elasticache_connection.py
# 6. Deploy application using scripts/deploy_to_aws.py
#
# Security Checklist:
# - Generate unique SECRET_KEY and JWT_SECRET_KEY
# - Store sensitive credentials in AWS Secrets Manager
# - Configure VPC and security groups properly
# - Enable CloudWatch monitoring and alerting
# - Set up automated backups
# - Configure SSL/TLS for all connections
#
# Cost Optimization:
# - Start with cache.t4g.small instance type
# - Use single-node cluster initially
# - Enable automated scaling based on metrics
# - Set up cost alerts in AWS Billing
# - Review and optimize TTL settings based on usage patterns