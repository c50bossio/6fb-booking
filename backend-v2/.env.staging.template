# 6FB Booking Platform v2 - Staging Environment Configuration
# 
# 🔒 CRITICAL SECURITY NOTICE:
# - This file contains staging environment configuration
# - Copy to .env.staging and fill in actual staging values
# - Staging should mirror production but with test/development credentials
# - Never use production credentials in staging environment
# - All sensitive values must be set via environment variables

# =============================================================================
# CORE APPLICATION SETTINGS
# =============================================================================
ENVIRONMENT=staging
LOG_LEVEL=INFO
DEBUG=false

# Application name and version
APP_NAME=6FB Booking API v2
APP_VERSION=2.0.0

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Staging PostgreSQL (managed by Terraform)
DATABASE_URL=postgresql://staging_admin:staging_password_123!@bookedbarber-db-staging.cluster-xyz.us-east-1.rds.amazonaws.com:5432/bookedbarber_staging

# Database pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================
# 🔒 STAGING SECURITY KEYS - Generate unique keys for staging
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
STAGING_SECRET_KEY=staging-secret-key-generate-unique-value-for-staging-environment
STAGING_JWT_SECRET_KEY=staging-jwt-secret-key-generate-unique-value-for-staging

# JWT Settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password security
BCRYPT_ROUNDS=12

# =============================================================================
# STRIPE PAYMENT CONFIGURATION (TEST MODE)
# =============================================================================
# Use Stripe TEST keys for staging environment
# Get these from https://dashboard.stripe.com/test/apikeys

STAGING_STRIPE_SECRET_KEY=sk_test_staging_stripe_secret_key_here
STAGING_STRIPE_PUBLISHABLE_KEY=pk_test_staging_stripe_publishable_key_here
STAGING_STRIPE_WEBHOOK_SECRET=whsec_staging_webhook_secret_here

# Stripe Connect (for barber payouts)
STAGING_STRIPE_CONNECT_CLIENT_ID=ca_staging_connect_client_id

# =============================================================================
# GOOGLE CALENDAR INTEGRATION (STAGING PROJECT)
# =============================================================================
# Create separate Google Cloud project for staging
# Enable Google Calendar API and create OAuth 2.0 credentials

GOOGLE_CLIENT_ID=staging_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=staging_google_client_secret
GOOGLE_REDIRECT_URI=https://staging.bookedbarber.com/api/calendar/callback

# =============================================================================
# EMAIL CONFIGURATION (STAGING SENDGRID ACCOUNT)
# =============================================================================
# Use separate SendGrid account/subuser for staging
# Get API key from: https://app.sendgrid.com/settings/api_keys

STAGING_SENDGRID_API_KEY=SG.staging_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=staging@bookedbarber.com
SENDGRID_FROM_NAME=BookedBarber Staging

# =============================================================================
# SMS CONFIGURATION (STAGING TWILIO ACCOUNT)
# =============================================================================
# Use separate Twilio account/subaccount for staging
# Get credentials from: https://console.twilio.com

STAGING_TWILIO_ACCOUNT_SID=AC_staging_twilio_account_sid_here
STAGING_TWILIO_AUTH_TOKEN=staging_twilio_auth_token_here
STAGING_TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# REDIS CONFIGURATION (ELASTICACHE)
# =============================================================================
# Redis managed by Terraform in staging
REDIS_URL=redis://bookedbarber-redis-staging.xyz.cache.amazonaws.com:6379/0

# Redis settings
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5

# =============================================================================
# NOTIFICATION SETTINGS
# =============================================================================
# Timing for appointment reminders (hours before appointment)
APPOINTMENT_REMINDER_HOURS=[24,2]

# Notification retry settings
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY_SECONDS=60

# =============================================================================
# BOOKING CONFIGURATION
# =============================================================================
# Business rules for booking system
BOOKING_MIN_LEAD_TIME_MINUTES=15
BOOKING_MAX_ADVANCE_DAYS=30
BOOKING_SAME_DAY_CUTOFF=17:00

# Default timezone
DEFAULT_TIMEZONE=America/New_York

# =============================================================================
# CORS & FRONTEND CONFIGURATION
# =============================================================================
# Staging domain configurations
ALLOWED_ORIGINS=https://staging.bookedbarber.com,https://api-staging.bookedbarber.com
FRONTEND_URL=https://staging.bookedbarber.com

# =============================================================================
# MONITORING & ERROR TRACKING (STAGING SENTRY PROJECT)
# =============================================================================
# Create separate Sentry project for staging
# Get DSN from: https://sentry.io/settings/[org]/projects/[staging-project]/keys/

STAGING_SENTRY_DSN=https://staging_sentry_dsn@sentry.io/staging_project_id
SENTRY_ENVIRONMENT=staging

# Sentry Configuration for staging
SENTRY_RELEASE=""
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.3
SENTRY_PROFILES_SAMPLE_RATE=0.2
SENTRY_DEBUG=false
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ATTACH_STACKTRACE=true
SENTRY_INCLUDE_LOCAL_VARIABLES=true
SENTRY_MAX_BREADCRUMBS=100

# =============================================================================
# RATE LIMITING
# =============================================================================
# Slightly relaxed rate limits for staging testing
RATE_LIMIT_PER_MINUTE=200
AUTH_RATE_LIMIT_PER_MINUTE=20

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable features for staging testing
ENABLE_GOOGLE_CALENDAR=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_WEBHOOKS=true

# =============================================================================
# STAGING SPECIFIC SETTINGS
# =============================================================================
# Staging infrastructure settings
AWS_REGION=us-east-1
GCP_PROJECT_ID=bookedbarber-staging
GCP_REGION=us-central1

# Load balancer and CDN
LOAD_BALANCER_DNS=bookedbarber-alb-staging-xyz.us-east-1.elb.amazonaws.com
CLOUDFRONT_DOMAIN=xyz123.cloudfront.net

# S3 bucket for staging assets
S3_ASSETS_BUCKET=bookedbarber-assets-staging-xyz

# =============================================================================
# SSL/TLS CONFIGURATION
# =============================================================================
# SSL settings for staging
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
SECURE_CONTENT_TYPE_NOSNIFF=true
SECURE_BROWSER_XSS_FILTER=true
SECURE_COOKIE_HTTPONLY=true
SECURE_COOKIE_SECURE=true
SECURE_COOKIE_SAMESITE=Lax

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
# Staging backup settings (less frequent than production)
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * 0  # Weekly on Sunday at 3 AM
BACKUP_RETENTION_DAYS=14   # 2 weeks retention

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
# Test database (separate from staging database)
TEST_DATABASE_URL=sqlite:///./test_staging.db

# =============================================================================
# MARKETING SUITE CONFIGURATION (TEST MODE)
# =============================================================================
# Marketing settings for staging testing
MARKETING_EMAIL_COST=0.0  # Free for staging testing
MARKETING_EMAIL_FREE_MONTHLY=10000  # High limit for testing
MARKETING_SMS_COST=0.0  # Free for staging testing
MARKETING_SMS_FREE_MONTHLY=1000  # High limit for testing
LAST_MINUTE_SMS_COST=0.0  # Free for staging testing

# Marketing limits (higher for testing)
MARKETING_MAX_RECIPIENTS_PER_CAMPAIGN=100  # Lower than production
MARKETING_RATE_LIMIT_PER_HOUR=100  # Lower than production

# =============================================================================
# DEPLOYMENT INFORMATION
# =============================================================================
# Deployment metadata
DEPLOYMENT_ENVIRONMENT=staging
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_DATE=2025-07-03
DEPLOYMENT_VERSION=v2.0.0-staging

# Container settings
CONTAINER_CPU=512
CONTAINER_MEMORY=1024
CONTAINER_REPLICAS=2

# Health check settings
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_RETRIES=3

# =============================================================================
# IMPORTANT STAGING NOTES
# =============================================================================
# 1. This is a staging environment - not for production use
# 2. Use test/staging credentials for all external services
# 3. Data may be reset periodically for testing
# 4. SSL certificates should be valid but can be self-signed
# 5. Monitor costs as staging should be much cheaper than production
# 6. Test all features before promoting to production
# 7. Use staging for integration testing and user acceptance testing
# 8. Keep staging environment up-to-date with production configuration