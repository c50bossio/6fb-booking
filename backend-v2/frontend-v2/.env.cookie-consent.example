# Cookie Consent & Analytics Configuration
# These environment variables are used by the cookie consent system

# Google Analytics Measurement ID (optional)
# Get this from your Google Analytics 4 property
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Meta Pixel ID (optional) 
# Get this from your Facebook Ads Manager
NEXT_PUBLIC_META_PIXEL_ID=

# Google Site Verification (optional)
# For Google Search Console verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
