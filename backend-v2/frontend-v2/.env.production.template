# 6FB Booking Platform v2 - PRODUCTION Frontend Configuration
# Copy this file to .env.production and fill in SECURE production values

# =============================================================================
# PRODUCTION ENVIRONMENT
# =============================================================================
NODE_ENV=production

# =============================================================================
# PRODUCTION URLS
# =============================================================================
# Backend API URL (your production backend)
NEXT_PUBLIC_API_URL=https://api.bookedbarber.com

# Frontend app URL (your production frontend)
NEXT_PUBLIC_APP_URL=https://app.bookedbarber.com

# =============================================================================
# STRIPE PRODUCTION CONFIGURATION (LIVE KEYS)
# =============================================================================
# Get LIVE keys from: https://dashboard.stripe.com/apikeys
# These are LIVE keys - handle payments with real money
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_LIVE_PUBLISHABLE_KEY_HERE

# =============================================================================
# ANALYTICS & TRACKING (Production)
# =============================================================================
# Google Analytics 4 (Production property)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-YOUR_PRODUCTION_GA_ID

# Google Tag Manager (Production container)
NEXT_PUBLIC_GTM_ID=GTM-YOUR_PRODUCTION_GTM_ID

# Meta (Facebook) Pixel (Production)
NEXT_PUBLIC_META_PIXEL_ID=YOUR_PRODUCTION_PIXEL_ID

# =============================================================================
# ERROR TRACKING (Production)
# =============================================================================
# Sentry for production error tracking
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_PRODUCTION_SENTRY_DSN@sentry.io/PROJECT_ID
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# =============================================================================
# GOOGLE SERVICES (Production)
# =============================================================================
# Google Maps API Key (Production key with restrictions)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_PRODUCTION_GOOGLE_MAPS_API_KEY

# Google Business integrations
NEXT_PUBLIC_GOOGLE_BUSINESS_ENABLED=true
NEXT_PUBLIC_GOOGLE_RESERVE_ENABLED=true

# =============================================================================
# PRODUCTION FEATURE FLAGS
# =============================================================================
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_CALENDAR_INTEGRATION=true
NEXT_PUBLIC_ENABLE_SMS_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_EMAIL_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_WEBHOOKS=true
NEXT_PUBLIC_ENABLE_ADMIN_PANEL=true

# IMPORTANT: Disable demo mode in production
NEXT_PUBLIC_DEMO_MODE=false

# =============================================================================
# BUSINESS BRANDING (Production)
# =============================================================================
NEXT_PUBLIC_BUSINESS_NAME=BookedBarber
NEXT_PUBLIC_BUSINESS_PHONE=+1-555-BARBER-1
NEXT_PUBLIC_BUSINESS_EMAIL=support@bookedbarber.com

# Production theme colors
NEXT_PUBLIC_PRIMARY_COLOR=#0f172a
NEXT_PUBLIC_SECONDARY_COLOR=#f8fafc
NEXT_PUBLIC_ACCENT_COLOR=#0ea5e9

# =============================================================================
# API CONFIGURATION (Production)
# =============================================================================
# Higher timeout for production (better reliability)
NEXT_PUBLIC_API_TIMEOUT=45000

# Production retry configuration
NEXT_PUBLIC_API_RETRY_ATTEMPTS=3
NEXT_PUBLIC_API_RETRY_DELAY=2000

# =============================================================================
# PRODUCTION OPTIMIZATIONS
# =============================================================================
# Disable debug features in production
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_USE_MOCK_DATA=false
NEXT_PUBLIC_ENABLE_DEVTOOLS=false

# Enable all performance optimizations
NEXT_PUBLIC_IMAGE_OPTIMIZATION=true

# =============================================================================
# BOOKING WIDGET (Production)
# =============================================================================
NEXT_PUBLIC_WIDGET_THEME=light
NEXT_PUBLIC_WIDGET_PRIMARY_COLOR=#0f172a
NEXT_PUBLIC_WIDGET_BORDER_RADIUS=8

# =============================================================================
# TIMEZONE (Production)
# =============================================================================
# Business timezone
NEXT_PUBLIC_DEFAULT_TIMEZONE=America/New_York

# =============================================================================
# BUILD CONFIGURATION (Production)
# =============================================================================
BUILD_ENV=production
BUILD_VERSION=2.0.0

# Sentry release tracking
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=6fb-booking-frontend
SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN

# =============================================================================
# PRODUCTION INTEGRATIONS
# =============================================================================
# Customer support (production)
NEXT_PUBLIC_INTERCOM_APP_ID=YOUR_PRODUCTION_INTERCOM_APP_ID
NEXT_PUBLIC_CRISP_WEBSITE_ID=YOUR_PRODUCTION_CRISP_ID

# Marketing tools (production)
NEXT_PUBLIC_HOTJAR_ID=YOUR_PRODUCTION_HOTJAR_ID
NEXT_PUBLIC_MIXPANEL_TOKEN=YOUR_PRODUCTION_MIXPANEL_TOKEN

# =============================================================================
# SECURITY (Production)
# =============================================================================
# Enable all security features
NEXT_PUBLIC_CSP_ENABLED=true
NEXT_PUBLIC_SECURITY_HEADERS=true

# =============================================================================
# NOTIFICATIONS (Production)
# =============================================================================
NEXT_PUBLIC_ENABLE_BROWSER_NOTIFICATIONS=true

# Web push notifications (if implemented)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY

# =============================================================================
# DEPLOYMENT PLATFORM VARIABLES (Production)
# =============================================================================
# These are set automatically by deployment platforms

# Railway Production
# RAILWAY_PUBLIC_DOMAIN=app.bookedbarber.com
# RAILWAY_ENVIRONMENT=production

# Render Production
# RENDER_EXTERNAL_URL=https://app.bookedbarber.com

# Vercel Production
# VERCEL_URL=app.bookedbarber.com
# VERCEL_ENV=production

# =============================================================================
# PERFORMANCE MONITORING
# =============================================================================
# Enable performance tracking in production
NEXT_PUBLIC_PERFORMANCE_MONITORING=true

# =============================================================================
# TESTING CONFIGURATION (Production E2E Tests)
# =============================================================================
# Test user for production E2E testing (use dedicated test account)
NEXT_PUBLIC_TEST_MODE=false
NEXT_PUBLIC_E2E_TEST_USER_EMAIL=test@bookedbarber.com
NEXT_PUBLIC_E2E_TEST_USER_PASSWORD=secure_test_password

# =============================================================================
# CDN CONFIGURATION
# =============================================================================
# If using a CDN for static assets
NEXT_PUBLIC_CDN_URL=https://cdn.bookedbarber.com

# =============================================================================
# IMPORTANT PRODUCTION NOTES
# =============================================================================
# 1. ALL VALUES ABOVE MUST BE REPLACED WITH REAL PRODUCTION VALUES
# 2. NEVER use test/development keys in production
# 3. Test all integrations thoroughly before going live
# 4. Monitor error rates and performance after deployment
# 5. Regularly update API keys and tokens
# 6. Keep analytics and tracking up to date
# 7. Ensure all external services are properly configured
# 8. Test payment flows with small amounts before full launch
# 9. Set up proper error monitoring and alerting
# 10. Have a rollback plan ready
#
# PRODUCTION CHECKLIST:
# [ ] All URLs point to production domains
# [ ] Live Stripe keys are configured (not test keys)
# [ ] Analytics tracking IDs are for production properties
# [ ] Error tracking is configured and tested
# [ ] Google Maps API key has production restrictions
# [ ] Demo mode is disabled
# [ ] Debug features are disabled
# [ ] All third-party integrations are using production credentials
# [ ] Performance monitoring is enabled
# [ ] Security headers are enabled
# [ ] Business information is accurate
# [ ] Test user accounts are configured properly
# [ ] CDN configuration is optimized
# [ ] All feature flags are set appropriately for production