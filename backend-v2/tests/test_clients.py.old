def test_delete_client_as_admin():
    """Test deleting a client as admin"""
    # Create admin user
    create_test_user("admin@example.com", role="admin")
    token = get_auth_token("admin@example.com")
    
    # Create a client
    create_response = client.post(
        "/api/v1/clients/",
        json={
            "first_name": "Delete",
            "last_name": "Me",
            "email": "delete@example.com",
            "phone": "+1212121212"
        },
        headers={"Authorization": f"Bearer {token}"}
    )
    client_id = create_response.json()["id"]
    
    # Delete the client
    response = client.delete(
        f"/api/v1/clients/{client_id}",
        headers={"Authorization": f"Bearer {token}"}
    )
    
    assert response.status_code == 200
    assert "deleted successfully" in response.json()["message"]
    
    # Verify deletion
    get_response = client.get(
        f"/api/v1/clients/{client_id}",
        headers={"Authorization": f"Bearer {token}"}
    )
    assert get_response.status_code == 404


def test_delete_client_as_non_admin():
    """Test that non-admin users cannot delete clients"""
    # Create regular user
    create_test_user("regular@example.com", role="user")
    token = get_auth_token("regular@example.com")
    
    # Create a client
    create_response = client.post(
        "/api/v1/clients/",
        json={
            "first_name": "No",
            "last_name": "Delete",
            "email": "nodelete@example.com",
            "phone": "+1313131313"
        },
        headers={"Authorization": f"Bearer {token}"}
    )
    client_id = create_response.json()["id"]
    
    # Try to delete as non-admin
    response = client.delete(
        f"/api/v1/clients/{client_id}",
        headers={"Authorization": f"Bearer {token}"}
    )
    
    assert response.status_code == 403
    assert "Only admins can delete" in response.json()["detail"]


def test_quick_search():
    """Test quick search endpoint for autocomplete"""
    # Reuse the same user
    token = get_auth_token("client_test_user@example.com")
    
    # Create test clients
    test_clients = [
        {
            "first_name": "Quick",
            "last_name": "Search",
            "email": "quick@example.com",
            "phone": "+1414141414"
        },
        {
            "first_name": "Quick",
            "last_name": "Find",
            "email": "find@example.com",
            "phone": "+1515151515"
        },
        {
            "first_name": "Slow",
            "last_name": "Search",
            "email": "slow@example.com",
            "phone": "+1616161616"
        }
    ]
    
    for client_data in test_clients:
        client.post(
            "/api/v1/clients/",
            json=client_data,
            headers={"Authorization": f"Bearer {token}"}
        )
    
    # Search for "Quick"
    response = client.post(
        "/api/v1/clients/search",
        params={"query": "Quick", "limit": 5},
        headers={"Authorization": f"Bearer {token}"}
    )
    
    assert response.status_code == 200
    data = response.json()
    assert len(data) == 2
    assert all("Quick" in item["name"] for item in data)
    assert all(key in item for key in ["id", "name", "email", "phone"] for item in data)


def test_unauthorized_access():
    """Test accessing client endpoints without authentication"""
    # Try to access without token
    endpoints = [
        ("GET", "/api/v1/clients/"),
        ("POST", "/api/v1/clients/"),
        ("GET", "/api/v1/clients/1"),
        ("PUT", "/api/v1/clients/1"),
        ("DELETE", "/api/v1/clients/1"),
        ("GET", "/api/v1/clients/1/history"),
        ("PUT", "/api/v1/clients/1/customer-type"),
        ("POST", "/api/v1/clients/search")
    ]
    
    for method, endpoint in endpoints:
        if method == "GET":
            response = client.get(endpoint)
        elif method == "POST":
            response = client.post(endpoint, json={})
        elif method == "PUT":
            response = client.put(endpoint, json={})
        elif method == "DELETE":
            response = client.delete(endpoint)
        
        assert response.status_code == 403  # FastAPI returns 403 for missing credentials


