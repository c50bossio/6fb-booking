        )
        
        assert response.status_code == 200
        data = response.json()
        assert "message" in data
        assert "notifications_queued" in data

class TestNotificationIntegration:
    """Integration tests for notification system"""
    
    def test_appointment_confirmation_flow(self, db_session, test_user, test_appointment, notification_templates):
        """Test complete appointment confirmation notification flow"""
        service = NotificationService()
        
        # Create context for confirmation
        context = {
            "client_name": test_user.name,
            "service_name": test_appointment.service_name,
            "appointment_date": test_appointment.start_time.strftime("%B %d, %Y"),
            "appointment_time": test_appointment.start_time.strftime("%I:%M %p"),
            "duration": test_appointment.duration_minutes,
            "price": test_appointment.price,
            "business_name": "Test Business"
        }
        
        # Queue confirmation notifications
        notifications = service.queue_notification(
            db=db_session,
            user=test_user,
            template_name="appointment_confirmation",
            context=context,
            appointment_id=test_appointment.id
        )
        
        assert len(notifications) >= 1
        
        # Verify notifications are in database
        queued = db_session.query(NotificationQueue).filter(
            NotificationQueue.appointment_id == test_appointment.id,
            NotificationQueue.template_name == "appointment_confirmation"
        ).all()
        
        assert len(queued) >= 1
        assert all(n.status == NotificationStatus.PENDING for n in queued)
    
    def test_notification_retry_logic(self, db_session, test_user, notification_templates):
        """Test notification retry logic"""
        service = NotificationService()
        
        # Create a notification that will fail
        notification = NotificationQueue(
            user_id=test_user.id,
            notification_type="email",
            template_name="appointment_confirmation",
            recipient="invalid@email",
            body="Test notification",
            status=NotificationStatus.PENDING,
            scheduled_for=datetime.utcnow(),
            attempts=0
        )
        
        db_session.add(notification)
        db_session.commit()
        db_session.refresh(notification)
        
        # Mock email sending to fail
        with patch.object(service, 'send_email') as mock_send:
            mock_send.return_value = {
                "success": False,
                "error": "Connection timeout",
                "should_retry": True
            }
            
            # Process the queue
            result = service.process_notification_queue(db_session)
            
            # Refresh notification from database
            db_session.refresh(notification)
            
            # Check that retry was scheduled
            assert notification.attempts == 1
            assert notification.status == NotificationStatus.PENDING
            assert notification.scheduled_for > datetime.utcnow()

class TestNotificationTemplates:
    """Test notification template functionality"""
    
    def test_template_rendering(self):
        """Test template rendering with context"""
        service = NotificationService()
        
        # Create a mock template
        template = Mock()
        template.template_type = "email"
        template.body = "Hello {{ client_name }}, your appointment is on {{ date }}"
        template.subject = "Appointment for {{ client_name }}"
        
        context = {
            "client_name": "John Doe",
            "date": "2024-01-01"
        }
        
        rendered = service.render_template(template, context)
        
        assert "John Doe" in rendered["body"]
        assert "2024-01-01" in rendered["body"]
        assert "John Doe" in rendered["subject"]
    
    def test_template_error_handling(self):
        """Test template rendering error handling"""
        service = NotificationService()
        
        # Create a template with invalid syntax
        template = Mock()
        template.template_type = "email"
        template.body = "Hello {{ client_name"  # Missing closing brace
        template.subject = "Test"
        template.name = "test_template"
        
        context = {"client_name": "John Doe"}
        
        with pytest.raises(Exception):
            service.render_template(template, context)

if __name__ == "__main__":
    pytest.main([__file__])