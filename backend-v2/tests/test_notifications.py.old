class TestNotificationService:
    """Test the NotificationService class"""
    
    def test_notification_service_initialization(self):
        """Test that notification service initializes correctly"""
        service = NotificationService()
        assert service is not None
        assert hasattr(service, 'stats')
        assert 'emails_sent' in service.stats
        assert 'sms_sent' in service.stats
    
    def test_format_phone_number(self):
        """Test phone number formatting"""
        service = NotificationService()
        
        # Test US number without country code
        assert service._format_phone_number("5551234567") == "+15551234567"
        
        # Test US number with country code
        assert service._format_phone_number("15551234567") == "+15551234567"
        
        # Test already formatted number
        assert service._format_phone_number("+15551234567") == "+15551234567"
        
        # Test invalid number
        assert service._format_phone_number("123") is None
        assert service._format_phone_number("") is None
    
    def test_is_retryable_error(self):
        """Test error retry detection"""
        service = NotificationService()
        
        # Retryable errors
        assert service._is_retryable_error("Connection timeout")
        assert service._is_retryable_error("Service unavailable")
        assert service._is_retryable_error("Rate limit exceeded")
        assert service._is_retryable_error("502 Bad Gateway")
        
        # Non-retryable errors
        assert not service._is_retryable_error("Invalid email address")
        assert not service._is_retryable_error("Authentication failed")
    
    def test_is_retryable_twilio_error(self):
        """Test Twilio error retry detection"""
        service = NotificationService()
        
        # Retryable codes
        assert service._is_retryable_twilio_error(20429)  # Too Many Requests
        assert service._is_retryable_twilio_error(30001)  # Queue overflow
        
        # Non-retryable codes
        assert not service._is_retryable_twilio_error(21211)  # Invalid 'To' Phone Number
        assert not service._is_retryable_twilio_error(21610)  # Unsubscribed recipient
    
    @patch('services.notification_service.SendGridAPIClient')
    def test_send_email_success(self, mock_sendgrid):
        """Test successful email sending"""
        # Mock SendGrid response
        mock_response = Mock()
        mock_response.status_code = 202
        mock_sendgrid.return_value.send.return_value = mock_response
        
        service = NotificationService()
        service.sendgrid_client = mock_sendgrid.return_value
        
        result = service.send_email(
            to_email="test@example.com",
            subject="Test Subject",
            body="Test Body"
        )
        
        assert result["success"] is True
        assert result["status_code"] == 202
        assert service.stats["emails_sent"] == 1
    
    @patch('services.notification_service.SendGridAPIClient')
    def test_send_email_failure(self, mock_sendgrid):
        """Test email sending failure"""
        # Mock SendGrid error
        mock_sendgrid.return_value.send.side_effect = Exception("SendGrid error")
        
        service = NotificationService()
        service.sendgrid_client = mock_sendgrid.return_value
        
        result = service.send_email(
            to_email="test@example.com",
            subject="Test Subject",
            body="Test Body"
        )
        
        assert result["success"] is False
        assert "error" in result
        assert service.stats["emails_failed"] == 1
    
    @patch('services.notification_service.TwilioClient')
    def test_send_sms_success(self, mock_twilio):
        """Test successful SMS sending"""
        # Mock Twilio response
        mock_message = Mock()
        mock_message.sid = "test_sid"
        mock_message.status = "sent"
        mock_twilio.return_value.messages.create.return_value = mock_message
        
        service = NotificationService()
        service.twilio_client = mock_twilio.return_value
        
        result = service.send_sms(
            to_phone="+15551234567",
            body="Test SMS"
        )
        
        assert result["success"] is True
        assert result["message_sid"] == "test_sid"
        assert service.stats["sms_sent"] == 1
    
    def test_queue_notification(self, db_session, test_user, notification_templates):
        """Test notification queuing"""
        service = NotificationService()
        
        context = {
            "client_name": "Test User",
            "appointment_date": "2024-01-01"
        }
        
        notifications = service.queue_notification(
            db=db_session,
            user=test_user,
            template_name="appointment_confirmation",
            context=context
        )
        
        assert len(notifications) >= 1  # Should create at least one notification
        
        # Check that notifications were added to database
        queued = db_session.query(NotificationQueue).filter(
            NotificationQueue.user_id == test_user.id
        ).all()
        
        assert len(queued) >= 1
        assert any(n.template_name == "appointment_confirmation" for n in queued)
    
    def test_schedule_appointment_reminders(self, db_session, test_appointment, notification_templates):
        """Test appointment reminder scheduling"""
        service = NotificationService()
        
        service.schedule_appointment_reminders(db_session, test_appointment)
        
        # Check that reminders were scheduled
        reminders = db_session.query(NotificationQueue).filter(
            NotificationQueue.appointment_id == test_appointment.id,
            NotificationQueue.template_name == "appointment_reminder"
        ).all()
        
        assert len(reminders) > 0
    
    def test_cancel_appointment_notifications(self, db_session, test_appointment, notification_templates):
        """Test cancelling appointment notifications"""
        service = NotificationService()
        
        # First, schedule some notifications
        service.schedule_appointment_reminders(db_session, test_appointment)
        
        # Then cancel them
        cancelled_count = service.cancel_appointment_notifications(
            db_session, 
            test_appointment.id
        )
        
        assert cancelled_count > 0
        
        # Check that notifications were cancelled
        cancelled = db_session.query(NotificationQueue).filter(
            NotificationQueue.appointment_id == test_appointment.id,
            NotificationQueue.status == NotificationStatus.CANCELLED
        ).all()
        
        assert len(cancelled) == cancelled_count

class TestNotificationAPI:
    """Test the notification API endpoints"""
    
    def test_get_notification_preferences(self, test_user, auth_headers):
        """Test getting notification preferences"""
        response = client.get(
            "/api/v1/notifications/preferences",
            headers=auth_headers
        )
        
        assert response.status_code == 200
        data = response.json()
        assert "email_enabled" in data
        assert "sms_enabled" in data
        assert "reminder_hours" in data
    
    def test_update_notification_preferences(self, test_user, auth_headers):
        """Test updating notification preferences"""
        preferences_data = {
            "email_enabled": False,
            "sms_enabled": True,
            "reminder_hours": [48, 4]
        }
        
        response = client.put(
            "/api/v1/notifications/preferences",
            headers=auth_headers,
            json=preferences_data
        )
        
        assert response.status_code == 200
        data = response.json()
        assert data["email_enabled"] is False
        assert data["sms_enabled"] is True
        assert data["reminder_hours"] == [48, 4]
    
    def test_get_notification_templates(self, test_user, auth_headers, notification_templates):
        """Test getting notification templates"""
        response = client.get(
            "/api/v1/notifications/templates",
            headers=auth_headers
        )
        
        assert response.status_code == 200
        data = response.json()
        assert len(data) >= 3  # We created 3 templates
        assert any(t["name"] == "appointment_confirmation" for t in data)
    
    def test_get_notification_history(self, test_user, auth_headers):
        """Test getting notification history"""
        response = client.get(
            "/api/v1/notifications/history",
            headers=auth_headers
        )
        
        assert response.status_code == 200
        data = response.json()
        assert isinstance(data, list)
    
    def test_get_notification_stats(self, test_user, auth_headers):
        """Test getting notification statistics"""
        response = client.get(
            "/api/v1/notifications/stats?days=7",
            headers=auth_headers
        )
        
        assert response.status_code == 200
        data = response.json()
        assert "period_days" in data
        assert "email" in data
        assert "sms" in data
        assert data["period_days"] == 7
    
    @patch('services.notification_service.notification_service.queue_notification')
