class TestErrorHandling:
    """Test error handling and edge cases."""
    
    @pytest.mark.asyncio
    async def test_rate_limiting(self, async_client, auth_headers):
        """Test rate limiting is enforced."""
        # Make multiple rapid requests
        responses = []
        for _ in range(100):
            response = await async_client.get(
                "/api/v1/resources/",
                headers=auth_headers
            )
            responses.append(response)
        
        # Check if rate limit was hit
        rate_limited = any(r.status_code == 429 for r in responses)
        assert rate_limited, "Rate limiting not enforced"
    
    @pytest.mark.asyncio
    async def test_database_connection_error(self, async_client, auth_headers, monkeypatch):
        """Test graceful handling of database errors."""
        # Mock database error
        def mock_get_db():
            raise Exception("Database connection failed")
        
        monkeypatch.setattr("dependencies.get_db", mock_get_db)
        
        response = await async_client.get(
            "/api/v1/resources/",
            headers=auth_headers
        )
        
        assert response.status_code == status.HTTP_500_INTERNAL_SERVER_ERROR
        assert "database" in response.json()["detail"].lower()


