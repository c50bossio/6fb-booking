# ===== PERFORMANCE TESTS =====

@pytest.mark.slow  # Mark slow tests so they can be skipped in CI
class TestPerformance:
    """Performance and load tests."""
    
    @pytest.mark.asyncio
    async def test_endpoint_response_time(self, async_client, auth_headers):
        """Test endpoint responds within acceptable time."""
        import time
        
        start = time.time()
        response = await async_client.get(
            "/api/v1/resources/",
            headers=auth_headers
        )
        duration = time.time() - start
        
        assert response.status_code == status.HTTP_200_OK
        assert duration < 0.5, f"Response took {duration}s, expected < 0.5s"


# ===== UTILITY FUNCTIONS =====

def create_test_booking(db_session, user_id, barber_id, **kwargs):
    """Helper function to create test bookings."""
    booking = Booking(
        user_id=user_id,
        barber_id=barber_id,
        start_time=kwargs.get("start_time", datetime.now() + timedelta(days=1)),
        end_time=kwargs.get("end_time", datetime.now() + timedelta(days=1, hours=1)),
        service_name=kwargs.get("service_name", "Haircut"),
        price=kwargs.get("price", 50.00),
        status=kwargs.get("status", "pending")
    )
    db_session.add(booking)
    db_session.commit()
    db_session.refresh(booking)
    return booking


def assert_valid_datetime(date_string):
    """Assert that a string is a valid ISO datetime."""
    try:
        datetime.fromisoformat(date_string.replace('Z', '+00:00'))
    except (ValueError, AttributeError):
        pytest.fail(f"Invalid datetime format: {date_string}")


def assert_paginated_response(response_data):
    """Assert response has correct pagination structure."""
    assert "items" in response_data
    assert "total" in response_data
    assert "skip" in response_data
    assert "limit" in response_data
    assert isinstance(response_data["items"], list)
    assert isinstance(response_data["total"], int)
    assert isinstance(response_data["skip"], int)
    assert isinstance(response_data["limit"], int)