class TestAPIEndpoint:
    """Group related tests in a class for better organization."""
    
    @pytest.mark.asyncio
    async def test_create_resource_success(self, async_client, auth_headers, db_session):
        """Test successful resource creation."""
        # Prepare test data
        test_data = {
            "name": "Test Resource",
            "description": "A test resource",
            "value": 100
        }
        
        # Make request
        response = await async_client.post(
            "/api/v1/resources/",
            headers=auth_headers,
            json=test_data
        )
        
        # Assert response
        assert response.status_code == status.HTTP_201_CREATED
        data = response.json()
        assert data["name"] == test_data["name"]
        assert data["description"] == test_data["description"]
        assert "id" in data
        
        # Verify in database
        # Add database verification if needed
    
    @pytest.mark.asyncio
    async def test_create_resource_validation_error(self, async_client, auth_headers):
        """Test validation errors are handled correctly."""
        # Invalid data (missing required field)
        invalid_data = {
            "description": "Missing name field"
        }
        
        response = await async_client.post(
            "/api/v1/resources/",
            headers=auth_headers,
            json=invalid_data
        )
        
        assert response.status_code == status.HTTP_422_UNPROCESSABLE_ENTITY
        error_detail = response.json()["detail"]
        assert any("name" in str(error).lower() for error in error_detail)
    
    @pytest.mark.asyncio
    async def test_get_resource_not_found(self, async_client, auth_headers):
        """Test 404 response for non-existent resource."""
        response = await async_client.get(
            "/api/v1/resources/999999",
            headers=auth_headers
        )
        
        assert response.status_code == status.HTTP_404_NOT_FOUND
        assert "not found" in response.json()["detail"].lower()
    
    @pytest.mark.asyncio
    async def test_unauthorized_access(self, async_client):
        """Test endpoints require authentication."""
        response = await async_client.get("/api/v1/resources/")
        
        assert response.status_code == status.HTTP_401_UNAUTHORIZED
        assert response.json()["detail"] == "Not authenticated"
    
    @pytest.mark.asyncio
    async def test_list_resources_pagination(self, async_client, auth_headers, db_session):
        """Test pagination works correctly."""
        # Create multiple test resources
        # ... create test data ...
        
        # Test first page
        response = await async_client.get(
            "/api/v1/resources/?skip=0&limit=10",
            headers=auth_headers
        )
        
        assert response.status_code == status.HTTP_200_OK
        data = response.json()
        assert len(data["items"]) <= 10
        assert "total" in data
        assert "skip" in data
        assert "limit" in data
    
    @pytest.mark.asyncio
    async def test_update_resource_partial(self, async_client, auth_headers, db_session):
        """Test partial update (PATCH) of a resource."""
        # Create a resource first
        # ... create test resource ...
        resource_id = 1
        
        update_data = {"name": "Updated Name"}
        
        response = await async_client.patch(
            f"/api/v1/resources/{resource_id}",
            headers=auth_headers,
            json=update_data
        )
        
        assert response.status_code == status.HTTP_200_OK
        assert response.json()["name"] == update_data["name"]
    
    @pytest.mark.asyncio
    async def test_delete_resource_cascade(self, async_client, auth_headers, db_session):
