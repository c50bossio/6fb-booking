ENABLE_GOOGLE_CALENDAR=false  # Will enable after migrating OAuth credentials
ENABLE_SMS_NOTIFICATIONS=true  # Enabled - working Twilio credentials
ENABLE_EMAIL_NOTIFICATIONS=true  # Enabled - working SendGrid credentials
ENABLE_ANALYTICS=true
ENABLE_WEBHOOKS=true

